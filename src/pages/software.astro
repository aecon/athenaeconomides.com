---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Software & Tools" sideBarActiveItemID="software">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Software &amp; Tools</div>
    <div class="text-lg mb-8 text-base-content/70">
      Open-source tools I've developed for computational biology and image analysis.
      All projects are available on <a href="https://github.com/aecon" target="_blank" class="link link-primary">GitHub</a>.
    </div>
  </div>

  <div class="text-2xl w-full font-bold mb-2">General-Purpose Packages</div>

  <HorizontalCard
    title="AggreQuant"
    desc="Automated analysis pipeline for High Content Screens. Processes 384-well plates with 9 fields per well (10,368 images per plate) to quantify aggregate-positive cells. Performs illumination correction, deep learning segmentation (StarDist for nuclei, Cellpose for cells), and co-localization analysis to characterize aggregate inclusions in cells."
    url="https://github.com/aecon/AggreQuant"
    target="_blank"
    badge="Python"
    tags={['Deep learning', 'High content screening', 'StarDist', 'Cellpose']}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="PlateViewer"
    desc="A specialized visualization tool for high-content screening microscopy data, supporting GE InCell Analyzer conventions and focus metrics. Designed for interactive exploration of plate-based imaging experiments with built-in quality control and data navigation features."
    url="https://github.com/aecon/PlateViewer"
    target="_blank"
    badge="Python"
    tags={['Visualization', 'HCS', 'Microscopy', 'Quality control']}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="img3D"
    desc="A Python/C package for image processing of large, 3D (volumetric) image data. Designed for storing NumPy arrays in raw file format, handling NRRD metadata used in bio-imaging, and performing computations on image data with optional OpenMP parallelism. Used in multiple publications for whole-brain light-sheet microscopy analysis."
    url="https://github.com/aecon/img3D"
    target="_blank"
    badge="Python · C"
    tags={['3D imaging', 'Light-sheet microscopy', 'NumPy', 'OpenMP']}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="prionBrain3D"
    desc="Analysis tools for prion disease research using 3D whole-brain imaging data."
    url="https://github.com/aecon/prionBrain3D"
    target="_blank"
    badge="Python"
    tags={['Prion disease', '3D brain analysis']}
  />
  <div class="divider my-0"></div>

  <div class="text-2xl w-full font-bold mb-2 mt-10">Publication-Specific Pipelines</div>

  <HorizontalCard
    title="SleepBrains"
    desc="Image processing pipeline for microglia and plaque segmentation in whole murine brains, developed for a study on prime editing of the β1 adrenoceptor to restore physiological REM sleep in an Alzheimer's disease mouse model. Combines machine learning-based instance segmentation (ilastik) with deformable registration to the Allen Brain Atlas for region-specific quantification of pathological markers."
    url="https://github.com/aecon/SleepBrains"
    target="_blank"
    badge="Nature Communications 2025"
    tags={['Plaques', 'Microglia', 'Allen Brain Atlas', 'ilastik']}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="3D-microglia-netoglitazone"
    desc="Pipeline for quantifying brainwide, region-specific effects of the antidiabetic drug netoglitazone in Alzheimer's mouse models. Processes whole-brain 3D image stacks for automated microglia segmentation, surface-artifact removal, voxelization/smoothing, and registration to the Allen Brain Atlas."
    url="https://github.com/aecon/3D-microglia-netoglitazone"
    target="_blank"
    badge="PLoS One 2025"
    tags={['Microglia', '3D segmentation', 'Allen Brain Atlas']}
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="toxoplasma3D"
    desc="Pipeline for quantifying and mapping the brainwide spatial distribution of proteins delivered by engineered Toxoplasma gondii secretion systems. Detects ZsGreen+ cell volume from whole-brain 3D light-sheet microscopy (mesoSPIM) images, with artifact filtering and registration to the Allen Brain Atlas."
    url="https://github.com/aecon/toxoplasma3D"
    target="_blank"
    badge="Nature Microbiology 2024"
    tags={['Neuroscience', '3D segmentation', 'Allen Brain Atlas']}
  />
  <div class="divider my-0"></div>

  <div class="mt-8 mb-8 text-center">
    <a class="btn btn-primary" href="https://github.com/aecon" target="_blank">
      View all repositories on GitHub →
    </a>
  </div>
</BaseLayout>
